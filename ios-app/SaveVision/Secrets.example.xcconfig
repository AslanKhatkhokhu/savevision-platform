// Secrets.example.xcconfig — TEMPLATE (committed).
//
// Setup:
//   cp SaveVision/Secrets.example.xcconfig SaveVision/Secrets.xcconfig
// then fill in your values. Secrets.xcconfig is gitignored, so real tokens, your
// Team ID, and homeserver settings never enter version control, and they survive
// `xcodegen generate`.
//
// - DEVELOPMENT_TEAM feeds code signing + the MWDAT TeamID in Info.plist.
// - MWDAT_* feed the MWDAT dict via $(MWDAT_APP_ID) / $(MWDAT_CLIENT_TOKEN).
// - SAVEVISION_* feed the SaveVisionConfig dict in Info.plist (read in Config.swift).
//   Use bare hostnames (no scheme) — '//' starts a comment in xcconfig.

DEVELOPMENT_TEAM = REPLACE_WITH_APPLE_TEAM_ID

MWDAT_APP_ID = REPLACE_WITH_META_APP_ID
MWDAT_CLIENT_TOKEN = REPLACE_WITH_META_CLIENT_TOKEN

// Matrix homeserver + operator + TURN
SAVEVISION_HOMESERVER_HOST = matrix.your-domain
SAVEVISION_OPERATOR_USER_ID = @operator:your-domain
SAVEVISION_OPERATOR_ROOM_ID =
SAVEVISION_TURN_HOST = turn.your-domain
SAVEVISION_TURN_SECRET = REPLACE_WITH_COTURN_STATIC_AUTH_SECRET

// Error reporting — Sentry SDK → self-hosted Bugsink ("rustrak").
// Store the DSN WITHOUT the https:// scheme ('//' is a comment in xcconfig);
// Config.swift re-adds it. Empty disables Sentry.
SAVEVISION_SENTRY_DSN = <key>@ingest.your-bugsink-host/<project>
SAVEVISION_SENTRY_ENVIRONMENT = development
