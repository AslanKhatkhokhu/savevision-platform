<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SaveVision</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleName</key>
	<string>SaveVision</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- URL scheme used by the Meta Wearables DAT SDK to deep-link back from
	     the Meta AI app after the user approves glasses access. The same value
	     MUST be entered as a redirect/app-link scheme in the Meta dev portal. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>savevision</string>
			</array>
		</dict>
	</array>

	<!-- Meta Wearables DAT SDK configuration.
	     ClientToken + MetaAppID come from build settings defined in a gitignored
	     Secrets.xcconfig (copy Secrets.example.xcconfig → Secrets.xcconfig and
	     fill in YOUR app's values from the Meta dev portal — see README.md).
	     The token is therefore never committed. TeamID is your Apple team. -->
	<key>MWDAT</key>
	<dict>
		<key>AppLinkURLScheme</key>
		<string>savevision://</string>
		<key>ClientToken</key>
		<string>$(MWDAT_CLIENT_TOKEN)</string>
		<key>MetaAppID</key>
		<string>$(MWDAT_APP_ID)</string>
		<key>TeamID</key>
		<string>$(DEVELOPMENT_TEAM)</string>
		<!-- MWDAT 0.7 Display uses the Device Access Toolkit App Model (DAM). -->
		<key>startupOptions</key>
		<dict>
			<key>usesDam</key>
			<true/>
		</dict>
	</dict>

	<!-- SaveVision homeserver/operator/TURN settings. Values are injected from
	     the gitignored Secrets.xcconfig (so nothing real is committed); this file
	     only carries the $(...) build-setting references. Read in Config.swift. -->
	<key>SaveVisionConfig</key>
	<dict>
		<key>HomeserverHost</key>
		<string>$(SAVEVISION_HOMESERVER_HOST)</string>
		<key>OperatorUserID</key>
		<string>$(SAVEVISION_OPERATOR_USER_ID)</string>
		<key>OperatorRoomID</key>
		<string>$(SAVEVISION_OPERATOR_ROOM_ID)</string>
		<key>TurnHost</key>
		<string>$(SAVEVISION_TURN_HOST)</string>
		<key>TurnSecret</key>
		<string>$(SAVEVISION_TURN_SECRET)</string>
		<key>SentryDSN</key>
		<string>$(SAVEVISION_SENTRY_DSN)</string>
		<key>SentryEnvironment</key>
		<string>$(SAVEVISION_SENTRY_ENVIRONMENT)</string>
	</dict>

	<!-- Allow LAN homeservers during development (e.g. http://192.168.x.x:8008).
	     Remove for production; use HTTPS only. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>SaveVision connects to your Meta Ray-Ban glasses over Bluetooth to stream your point of view.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>SaveVision uses Bluetooth to receive audio and video from your Meta Ray-Ban glasses.</string>
	<key>NSCameraUsageDescription</key>
	<string>SaveVision uses the iPhone camera as a fallback when glasses are not connected, so you can test the call before pairing hardware.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>SaveVision uses the microphone so the remote operator can hear you during a call.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SaveVision shares your location with the operator during a call so a medic can find you.</string>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Keep the call (audio + glasses link) alive when the screen locks or the
	     app is backgrounded — essential for a hands-free wearer. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>voip</string>
		<string>bluetooth-central</string>
		<string>bluetooth-peripheral</string>
		<string>external-accessory</string>
	</array>

	<!-- Required so iOS surfaces the Meta glasses as an external accessory. -->
	<key>UISupportedExternalAccessoryProtocols</key>
	<array>
		<string>com.meta.ar.wearable</string>
	</array>

	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
